{
  "version": 2,
  "builds": [
    {
      "src": "server/app.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/chat/(.*)",
      "dest": "server/app.js"
    },
    {
      "src": "/api/chat",
      "dest": "server/app.js"
    },
    {
      "src": "/",
      "dest": "client/index.html"
    }
  ]
}